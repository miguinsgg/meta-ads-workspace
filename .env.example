# Token de acceso a Meta Marketing API
# Cómo conseguirlo:
#   1. Entra a https://developers.facebook.com/tools/explorer/
#   2. Selecciona tu app · permisos: ads_read, ads_management, business_management
#   3. Generate Access Token · pégalo abajo
# Tip: para producción, generá un token de larga duración (60 días)
ACCESS_TOKEN=tu_token_aqui

# ID de tu cuenta de anuncios (con prefijo act_)
# Lo encontrás en Ads Manager → arriba a la izquierda al lado del nombre de la cuenta
AD_ACCOUNT_ID=act_0000000000000000
